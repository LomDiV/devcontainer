{
    "name": "DevOps DevContainer",
    "image": "ghcr.io/lomdiv/devcontainer-devops:latest",
    "customizations": {
        "vscode": {
            "extensions": [
                "redhat.ansible",
                "redhat.vscode-yaml",
                "ms-kubernetes-tools.vscode-kubernetes-tools",
                "ms-azuretools.vscode-docker"
            ]
        }
    },
    "remoteUser": "dev",
    "mounts": [
        "source=${localEnv:HOME}/.kube,target=/home/dev/.kube,type=bind",
        "source=${localEnv:HOME}/.bash_history,target=/home/dev/.bash_history,type=bind",
        "source=${localEnv:HOME}/.gemini,target=/home/dev/.gemini,type=bind",
        "source=${localEnv:HOME}/.gitconfig,target=/home/dev/.gitconfig,type=bind",
        "source=${localEnv:HOME}/.ssh,target=/home/dev/.ssh,type=bind"
    ]
}